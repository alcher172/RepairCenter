#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Получем обхект отчета чтобы извлеч схему компоновки данных и настройки
	// это потребуется для заполнения списка доступных значений полей настроек
	// и для формировани диаграмм
	ОтчетОбъект = РеквизитФормыВЗначение("Отчет");
	Схема = ОтчетОбъект.СхемаКомпоновкиДанных;
	
	// Записываем нужные данных в хранилище значений
	СтруктураОтчета = Новый Структура;
	СтруктураОтчета.Вставить("КомпоновщикНастроек", ОтчетОбъект.КомпоновщикНастроек);
	СтруктураОтчета.Вставить("СхемаКомпоновкиДанных", Схема);	
	АдресНастроекОтчета = ПоместитьВоВременноеХранилище(СтруктураОтчета, УникальныйИдентификатор);

    // Заполнение доступных значений для параметров ГодНачало и ГодОкончание
	ЗаполнитьЗначенияПараметровПериода(Схема);
	
	// Устанавливаем видмость кнопок сортировки
	Элементы.ФормаСортироватьПоЗатратам.Видимость = ПолеЕстьВОтчете("РемонтыСумма");
	Элементы.СортироватьПоРемонтам.Видимость = ПолеЕстьВОтчете("Ремонты");
	Элементы.СортироватьПоСписаниям.Видимость = ПолеЕстьВОтчете("Списано");
	Элементы.СортироватьПоПроценту.Видимость = ПолеЕстьВОтчете("Процент");
	ВидимостьГруппы = (Элементы.ФормаСортироватьПоЗатратам.Видимость
		ИЛИ Элементы.СортироватьПоРемонтам.Видимость
		ИЛИ Элементы.СортироватьПоСписаниям.Видимость
		ИЛИ Элементы.СортироватьПоПроценту.Видимость);
	Элементы.ГруппаКнопкиСортировки.Видимость = ВидимостьГруппы;
	Элементы.ДекорацияЗаголовокСортировки.Видимость = ВидимостьГруппы;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ПодключитьОбработчикОжидания("УстановитьНеактуальность", 1);
	ВыбранныйВид = 1;
	УстановитьВидимостьСтраниц();
	
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВыбранныйВидПриИзменении(Элемент)
	УстановитьВидимостьСтраниц();
	
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СортироватьПоЗатратам(Команда)
	УстановитьСортировкуНаСервере("РемонтыСумма"); 
	СформироватьОтчетНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура СортироватьПоРемонтам(Команда)
	УстановитьСортировкуНаСервере("Ремонты"); 
	СформироватьОтчетНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура СортироватьПоСписаниям(Команда)
	УстановитьСортировкуНаСервере("Списано"); 
	СформироватьОтчетНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьСортировку(Команда)
	ОчиститьСортировкуНаСервере();
	СформироватьОтчетНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура Диаграммы(Команда)
	СформироватьОтчетНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура СортироватьПоПроценту(Команда)
	УстановитьСортировкуНаСервере("Процент"); 
	СформироватьОтчетНаСервере();
	
КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура УстановитьВидимостьСтраниц()
	Если ВыбранныйВид = 1 Тогда 
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаСтраницаТаблицы;
	ИначеЕсли ВыбранныйВид = 2 Тогда 
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаСтраницаДиаграммы;
	Иначе
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаСтраницаСовместно;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолеЕстьВОтчете(ИмяПоля)
	
	ИскомоеПоле = Новый ПолеКомпоновкиДанных(ИмяПоля);
	ДоступноеПоле = Отчет.КомпоновщикНастроек.Настройки.ДоступныеПоляВыбора.НайтиПоле(ИскомоеПоле);
	Если ДоступноеПоле <> Неопределено Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

&НаСервере
Функция ПолучитьПорядокСортировки()
	Порядок = Неопределено;
	Для Каждого Элемент Из Отчет.КомпоновщикНастроек.ПользовательскиеНастройки.Элементы Цикл
		Если ТипЗнч(Элемент) = Тип("ПорядокКомпоновкиДанных") Тогда
			Порядок = Элемент;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Порядок = Неопределено Тогда
		Порядок = Отчет.КомпоновщикНастроек.Настройки.Порядок;
	КонецЕсли;
	
	Возврат Порядок;
	
КонецФункции

&НаСервере
Процедура УстановитьСортировкуНаСервере(ИмяПоля)
	
	Порядок = ПолучитьПорядокСортировки();
	Если Порядок = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Порядок.Элементы.Очистить();
	НовыйПорядок = Порядок.Элементы.Добавить(Тип("ЭлементПорядкаКомпоновкиДанных"));
	НовыйПорядок.Поле = Новый ПолеКомпоновкиДанных(ИмяПоля);
	НовыйПорядок.ТипУпорядочивания = НаправлениеСортировкиКомпоновкиДанных.Убыв;
	НовыйПорядок.Использование = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЗначенияПараметровПериода(Схема)
	
	ДоступныеЗначенияПериода = Новый СписокЗначений;
    Для ТекГод = 2020 По Год(ТекущаяДата()) Цикл
        ДоступныеЗначенияПериода.Добавить(ТекГод, Формат(ТекГод, "ЧГ=;"));
    КонецЦикла;
    
    ПараметрСКД = Схема.Параметры.Найти("ГодНачало");    
    Если ПараметрСКД <> Неопределено Тогда
	    ПараметрСКД.УстановитьДоступныеЗначения(ДоступныеЗначенияПериода);
    КонецЕсли;
    
    ПараметрСКД = Схема.Параметры.Найти("ГодОкончание");    
    Если ПараметрСКД <> Неопределено Тогда
	    ПараметрСКД.УстановитьДоступныеЗначения(ДоступныеЗначенияПериода);
	КонецЕсли;
	
	// Обновляем ДоступныеПараметры во всех настройках
	Отчет.КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(Схема));
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьСортировкуНаСервере()
	
	Порядок = ПолучитьПорядокСортировки();
	Если Порядок = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Порядок.Элементы.Очистить();
	
КонецПроцедуры

&НаСервере
Процедура СформироватьОтчетНаСервере()

    // Получаем схему их хранилища
    Данные = ПолучитьИзВременногоХранилища(АдресНастроекОтчета);
    Схема = Данные.СхемаКомпоновкиДанных;
     
    // Вывод отчета в разных форматах в разные табличные документы
    ВывестиЧастьОтчета(Результат, Схема, "Все");
    ВывестиЧастьОтчета(РезультатТаблицы, Схема, "ТолькоТаблицы");
    ВывестиЧастьОтчета(РезультатДиаграммы, Схема, "ТолькоДиаграммы");
    
КонецПроцедуры

&НаКлиенте
Процедура УстановитьНеактуальность()
	// Копируем состояние актуальности из "штатного" элемента Результат
	Элементы.РезультатТаблицы.ОтображениеСостояния.Видимость = Элементы.Результат.ОтображениеСостояния.Видимость;
	Элементы.РезультатТаблицы.ОтображениеСостояния.ДополнительныйРежимОтображения
		= Элементы.Результат.ОтображениеСостояния.ДополнительныйРежимОтображения;
	Элементы.РезультатТаблицы.ОтображениеСостояния.Текст = Элементы.Результат.ОтображениеСостояния.Текст;
	Элементы.РезультатДиаграммы.ОтображениеСостояния.Видимость = Элементы.Результат.ОтображениеСостояния.Видимость;
	Элементы.РезультатДиаграммы.ОтображениеСостояния.ДополнительныйРежимОтображения
		= Элементы.Результат.ОтображениеСостояния.ДополнительныйРежимОтображения;
	Элементы.РезультатДиаграммы.ОтображениеСостояния.Текст = Элементы.Результат.ОтображениеСостояния.Текст;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиЧастьОтчета(ТабДок, Схема, Режим)
    
    ТабДок.Очистить();
    
    // Для каждого вывода нужно выгрузить из хранилища свой вариант настроек
    Данные = ПолучитьИзВременногоХранилища(АдресНастроекОтчета);
    ТекущиеНастройки = Данные.КомпоновщикНастроек.ПолучитьНастройки();
    
    //В зависимости от режима удаляем лишние элементы из структуры настроек
    Коллекция = ТекущиеНастройки.Структура;
    Индекс = Коллекция.Количество() - 1;
    Пока Индекс >= 0 Цикл
        Элемент = Коллекция[Индекс];
        ЭтоДиаграмма = (ТипЗнч(Элемент) = Тип("ДиаграммаКомпоновкиДанных"));
        Если Режим = "ТолькоТаблицы" И ЭтоДиаграмма Тогда
            Коллекция.Удалить(Элемент);
        ИначеЕсли Режим = "ТолькоДиаграммы" И НЕ ЭтоДиаграмма Тогда
            Коллекция.Удалить(Элемент);
        КонецЕсли;
        
        Индекс = Индекс - 1;
    КонецЦикла;
    
    // Стандартный процесс вывода отчата в табличный документ
    КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
    Макет = КомпоновщикМакета.Выполнить(Схема, ТекущиеНастройки);
    
    ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
    ПроцессорКомпоновки.Инициализировать(Макет);
    
    ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
    ПроцессорВывода.УстановитьДокумент(ТабДок);
    ПроцессорВывода.Вывести(ПроцессорКомпоновки);
    
    Элементы.Результат.ОтображениеСостояния.Видимость = Ложь;
 	Элементы.Результат.ОтображениеСостояния.ДополнительныйРежимОтображения
 		= ДополнительныйРежимОтображения.НеИспользовать;
    
КонецПроцедуры


#КонецОбласти





