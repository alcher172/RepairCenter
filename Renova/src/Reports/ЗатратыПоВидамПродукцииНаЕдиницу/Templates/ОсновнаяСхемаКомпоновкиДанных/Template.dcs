			<dataPath>МоделиПродукции</dataPath>
			<field>МоделиПродукции</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Год</dataPath>
			<field>Год</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Фирма</dataPath>
			<field>Фирма</field>
			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>МесяцУчета</dataPath>
			<field>МесяцУчета</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ГруппаМоделей</dataPath>
			<field>ГруппаМоделей</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Группа моделей</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	РемонтыИПродукцияОбороты.МодельПродукции КАК МодельПродукции,
	РемонтыИПродукцияОбороты.СуммаИтогоОборот КАК РемонтыСумма,
	ГОД(РемонтыИПродукцияОбороты.Период) КАК Год,
	РемонтыИПродукцияОбороты.КоличествоОборот КАК Ремонты
ПОМЕСТИТЬ ВТ_Ремонты
ИЗ
	РегистрНакопления.РемонтыИПродукция.Обороты(,, Год,) КАК РемонтыИПродукцияОбороты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	АктыПродукцияИКодОбороты.МодельПродукции КАК МодельПродукции,
	АктыПродукцияИКодОбороты.КоличествоОборот КАК Списано,
	ГОД(АктыПродукцияИКодОбороты.Период) КАК Год
ПОМЕСТИТЬ ВТ_Списания
ИЗ
	РегистрНакопления.АктыПродукцияИКод.Обороты(,, Год,) КАК АктыПродукцияИКодОбороты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ПродажиОбороты.МоделиПродукции КАК МодельПродукции,
	ПродажиОбороты.Фирма КАК Фирма,
	ПродажиОбороты.КоличествоОборот КАК Продажи,
	ГОД(ПродажиОбороты.Период) КАК Год,
	ВТ_Ремонты.Ремонты КАК Ремонты,
	ВТ_Ремонты.РемонтыСумма КАК РемонтыСумма,
	ВТ_Списания.Списано КАК Списано,
	ПродажиОбороты.ВидПродукции КАК ВидПродукции,
	ГруппыМоделей.Ссылка КАК ГруппаМоделей
ИЗ
	РегистрНакопления.Продажи.Обороты(,, Год,) КАК ПродажиОбороты
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Ремонты КАК ВТ_Ремонты
		ПО ПродажиОбороты.МоделиПродукции = ВТ_Ремонты.МодельПродукции
		И ГОД(ПродажиОбороты.Период) = ВТ_Ремонты.Год
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Списания КАК ВТ_Списания
		ПО ПродажиОбороты.МоделиПродукции = ВТ_Списания.МодельПродукции
		И ГОД(ПродажиОбороты.Период) = ВТ_Списания.Год
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ГруппыМоделей КАК ГруппыМоделей
		ПО ПродажиОбороты.МоделиПродукции = ГруппыМоделей.МодельПродукции.Модель</query>
	</dataSet>
	<calculatedField>
		<dataPath>НаЕдиницу</dataPath>
		<expression/>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>На единицу</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:decimal</v8:Type>
			<v8:NumberQualifiers>
				<v8:Digits>10</v8:Digits>
				<v8:FractionDigits>2</v8:FractionDigits>
				<v8:AllowedSign>Nonnegative</v8:AllowedSign>
			</v8:NumberQualifiers>
		</valueType>
	</calculatedField>
	<totalField>
		<dataPath>Ремонты</dataPath>
		<expression>Сумма(Ремонты)</expression>
	</totalField>
	<totalField>
		<dataPath>РемонтыСумма</dataPath>
		<expression>Сумма(РемонтыСумма)</expression>
	</totalField>
	<totalField>
		<dataPath>Списано</dataPath>
		<expression>Сумма(Списано)</expression>
	</totalField>
	<totalField>
		<dataPath>НаЕдиницу</dataPath>
		<expression>Окр(Сумма(РемонтыСумма)/Сумма(Продажи), 2)</expression>
	</totalField>
	<totalField>
		<dataPath>Продажи</dataPath>
		<expression>Сумма(Продажи)</expression>
	</totalField>
	<parameter>
		<name>НачалоПериода</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Начало периода</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<useRestriction>true</useRestriction>
		<expression>ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), "ГОД", &amp;ГодНачало - 1)
</expression>
		<availableAsField>false</availableAsField>
	</parameter>
	<parameter>
		<name>КонецПериода</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Конец периода</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<useRestriction>true</useRestriction>
		<expression>КонецПериода(ДОБАВИТЬКДАТЕ(ДАТАВРЕМЯ(1, 1, 1), "ГОД", &amp;ГодОкончание - 1),  "Год")</expression>
		<availableAsField>false</availableAsField>
	</parameter>
	<parameter>
		<name>ГодНачало</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Начало периода</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:decimal</v8:Type>
			<v8:NumberQualifiers>
				<v8:Digits>4</v8:Digits>
				<v8:FractionDigits>0</v8:FractionDigits>
				<v8:AllowedSign>Nonnegative</v8:AllowedSign>
			</v8:NumberQualifiers>
		</valueType>
		<value xsi:nil="true"/>
		<useRestriction>false</useRestriction>
	</parameter>
	<parameter>
		<name>ГодОкончание</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Конец периода</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:decimal</v8:Type>
			<v8:NumberQualifiers>
				<v8:Digits>4</v8:Digits>
				<v8:FractionDigits>0</v8:FractionDigits>
				<v8:AllowedSign>Nonnegative</v8:AllowedSign>
			</v8:NumberQualifiers>
		</valueType>
		<value xsi:nil="true"/>
		<useRestriction>false</useRestriction>
	</parameter>
