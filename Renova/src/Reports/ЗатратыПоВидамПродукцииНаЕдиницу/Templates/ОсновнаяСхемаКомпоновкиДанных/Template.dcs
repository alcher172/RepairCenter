			<dataPath>Продажи</dataPath>
			<field>Продажи</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Ремонты</dataPath>
			<field>Ремонты</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>РемонтыСумма</dataPath>
			<field>РемонтыСумма</field>
		</field>
		<field xsi:type="DataSetFieldField">
